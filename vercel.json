{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/widget.js",
      "destination": "/widget.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
